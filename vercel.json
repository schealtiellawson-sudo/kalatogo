{
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-XSS-Protection", "value": "1; mode=block" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=(self)" },
        { "key": "Strict-Transport-Security", "value": "max-age=63072000; includeSubDomains; preload" }
      ]
    }
  ],
  "crons": [
    { "path": "/api/cron/score-wolo", "schedule": "0 6 * * *" },
    { "path": "/api/cron/coup-du-jour", "schedule": "0 8 * * *" },
    { "path": "/api/cron/renouvellements", "schedule": "0 8 * * *" },
    { "path": "/api/cron/eligibilite-bourse", "schedule": "0 7 * * *" },
    { "path": "/api/cron/tirage-bourse", "schedule": "0 17 * * 5" },
    { "path": "/api/cron/awards-resultat", "schedule": "0 17 * * 5" }
  ],
  "rewrites": [
    { "source": "/api/airtable-proxy/:path*", "destination": "/api/airtable-proxy" },
    { "source": "/profil/:slug", "destination": "/api/profil-seo" },
    { "source": "/pay/:id", "destination": "/pay.html" },
    { "source": "/sitemap.xml", "destination": "/api/sitemap" }
  ]
}
